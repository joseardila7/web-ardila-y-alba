---
// =============================================
// LAYOUT PRINCIPAL — Plantilla base HTML5
// =============================================
// Envuelve todas las páginas. Proporciona:
//   - Estructura <html>, <head>, <body>
//   - Meta tags SEO (title, description, Open Graph)
//   - Datos estructurados JSON-LD (Schema.org)
//   - Estilos globales (Tailwind + brand colors)
//   - Header y Footer
//
// CÓMO USARLO EN UNA PÁGINA:
// ---
// import Layout from "../layouts/Layout.astro";
// ---
// <Layout
//   title="Título de la página"          ← aparece en la pestaña
//   description="Descripción SEO"         ← meta description
//   canonical="https://dominio.com/ruta"  ← URL canónica (opcional)
//   ogImage="/images/og-inicio.jpg"       ← imagen para redes sociales (opcional)
// >
//   <!-- Contenido específico de la página -->
// </Layout>
//
// PERSONALIZACIÓN:
//   - Meta tags globales → edita aquí mismo
//   - Datos de empresa   → edita src/data/company.ts
//   - Schema.org          → edita src/components/SEO.astro
// =============================================

import "../styles/global.css";
import { COMPANY } from "../data/company";
import { LOCAL_DATA } from "../data/seo";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SEO from "../components/SEO.astro";

export interface Props {
  /** Título de la página (aparece en la pestaña del navegador) */
  title: string;
  /** Meta description para buscadores (máx. 160 caracteres) */
  description: string;
  /** URL canónica (evita contenido duplicado en Google) */
  canonical?: string;
  /** Ruta de la imagen para Open Graph (relativa a public/) */
  ogImage?: string;
  /** Si es true, añade <meta name="robots" content="noindex" /> */
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage,
  noindex = false,
} = Astro.props;

const fullTitle = `${title} | ${COMPANY.shortName}`;
const finalOgImage = ogImage || LOCAL_DATA.ogImage;
const ogImageUrl = `${LOCAL_DATA.siteUrl}${finalOgImage}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ═══════════════════════════════════════
         META TAGS PRINCIPALES (SEO)
         ═══════════════════════════════════════ -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    {/* URL canónica — ayuda a evitar contenido duplicado */}
    {canonical && <link rel="canonical" href={canonical} />}

    {/* No index — para páginas legales provisionales */}
    {noindex && <meta name="robots" content="noindex" />}

    {/* Datos estructurados JSON-LD (Schema.org) */}
    <SEO />

    <!-- ═══════════════════════════════════════
         OPEN GRAPH (para compartir en redes)
         ═══════════════════════════════════════ -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical || LOCAL_DATA.siteUrl} />
    <meta property="og:site_name" content={COMPANY.shortName} />
    {/* og:image: imagen que se muestra al compartir en redes */}
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {/* og:locale: idioma y país */}
    <meta property="og:locale" content="es_ES" />

    <!-- ═══════════════════════════════════════
         FAVICON — sustituir por el logo real
         ═══════════════════════════════════════ -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>

  <body class="flex min-h-screen flex-col">
    {/* Navegación principal */}
    <Header />

    {/* Contenido principal (sin page-enter — el scroll reveal
         se encarga de las animaciones de entrada) */}
    <main class="flex-1">
      <slot />
    </main>

    {/* Pie de página */}
    <Footer />

    <!-- Scroll reveal: IntersectionObserver
         - Marca html.js para activar el CSS oculto.
         - Observa elementos .reveal* y añade .is-visible al entrar.
         - Una sola instancia, sin listeners de scroll.
         - Safety timeout a los 3s por si algo falla. -->
    <script>
      (function () {
        "use strict";

        // 1. Marcar JS como activo (activa los estilos ocultos en CSS)
        document.documentElement.classList.add("js");
        console.log("[ScrollReveal] JS cargado");

        var selector =
          ".reveal, .reveal-up, .reveal-left, .reveal-right, .reveal-scale";

        function revealAll() {
          document.querySelectorAll(selector).forEach(function (el) {
            el.classList.add("is-visible");
          });
          console.log("[ScrollReveal] Todos revelados (timeout/motion)");
        }

        // 2. Si no hay IntersectionObserver o el usuario prefiere
        //    reducir movimiento, revelar todo inmediatamente
        if (
          !("IntersectionObserver" in window) ||
          window.matchMedia("(prefers-reduced-motion: reduce)").matches
        ) {
          revealAll();
          return;
        }

        // 3. Contar elementos
        var elements = document.querySelectorAll(selector);
        console.log("[ScrollReveal] Elementos encontrados:", elements.length);

        if (elements.length === 0) return;

        // 4. Crear observer
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
        );

        // 5. Empezar a observar
        elements.forEach(function (el) {
          observer.observe(el);
        });
        console.log("[ScrollReveal] Observando", elements.length, "elementos");

        // 6. Safety timeout: revelar elementos que no se hayan visto
        //    después de 3 segundos
        setTimeout(revealAll, 3000);
      })();
    </script>
  </body>
</html>
