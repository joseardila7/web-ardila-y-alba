---
export interface Crumb {
  label: string;
  href?: string;
}

export interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-3 flex items-center gap-0 text-sm text-white/50">
  {crumbs.map((crumb, i) => (
    <span class="flex items-center">
      {i > 0 && <span class="breadcrumb-separator" aria-hidden="true">/</span>}
      {crumb.href ? (
        <a href={crumb.href} class="text-white/60 transition-colors duration-200 hover:text-brand-accent no-underline">
          {crumb.label}
        </a>
      ) : (
        <span class="text-white/80" aria-current="page">{crumb.label}</span>
      )}
    </span>
  ))}
</nav>
