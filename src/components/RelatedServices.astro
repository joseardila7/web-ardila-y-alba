---
import { SERVICES } from "../data/services";

export interface Props {
  slugs: string[];
  currentSlug?: string;
}

const { slugs, currentSlug } = Astro.props;

const related = SERVICES.filter(
  (s) => slugs.includes(s.slug) && s.slug !== currentSlug
);
---

{related.length > 0 && (
  <div class="reveal-up grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {related.map((service, i) => (
      <a
        href={`/servicios/${service.slug}`}
        class="reveal-up card-hover group block no-underline rounded-xl border border-gray-100 bg-white p-6 shadow-sm"
        style={`transition-delay: ${i * 80}ms`}
      >
        <div class="mb-3 flex h-12 w-12 items-center justify-center rounded-lg bg-brand-accent/10 text-xl transition-[transform,background-color] duration-300 group-hover:scale-110 group-hover:bg-brand-accent/20">
          <span aria-hidden="true">{service.icon}</span>
        </div>
        <h3 class="mb-2 font-semibold text-brand-dark transition-colors duration-300 group-hover:text-brand-accent">
          {service.title}
        </h3>
        <p class="text-sm leading-relaxed text-gray-600 line-clamp-2">
          {service.description}
        </p>
        <span class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-brand-accent transition-all duration-300 group-hover:gap-1.5">
          Ver servicio
          <span aria-hidden="true" class="link-arrow text-base">→</span>
        </span>
      </a>
    ))}
  </div>
)}
