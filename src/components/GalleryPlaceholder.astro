---
// =============================================
// GALLERYPLACEHOLDER — Cuadrícula de trabajos
// =============================================
// Mientras no haya fotos reales, muestra
// placeholders visuales con las categorías
// definidas en gallery.ts.
//
// CUANDO TENGAS FOTOS REALES:
//   Sustituye por <img> con alt descriptivo.
// =============================================

import { GALLERY_CATEGORIES } from "../data/gallery";

export interface Props {
  count?: number;
  columns?: 2 | 3 | 4;
  class?: string;
}

const { count = 6, columns = 3, class: className = "" } = Astro.props;

const gridCols: Record<number, string> = {
  2: "md:grid-cols-2",
  3: "md:grid-cols-3",
  4: "md:grid-cols-4",
};

// Ignoramos "Todos" (índice 0) y usamos las categorías reales
const categories = GALLERY_CATEGORIES.filter((_, i) => i > 0);
const items = Array.from({ length: count }, (_, i) => {
  const cat = categories[i % categories.length];
  return { id: i, category: cat };
});
---

<div class={`grid grid-cols-1 gap-4 sm:grid-cols-2 ${gridCols[columns]} ${className}`}>
  {items.map((item) => (
    <div
      class="group relative flex aspect-video animate-fade-up items-center justify-center overflow-hidden rounded-xl bg-gradient-to-br from-brand-surface-alt to-gray-200 shadow-sm transition-colors duration-200 hover:shadow-sm"
      style={`animation-delay: ${item.id * 80}ms; animation-fill-mode: both;`}
    >
      {/* Placeholder visual con categoría */}
      <div class="text-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto mb-2 h-10 w-10 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
          <circle cx="8.5" cy="8.5" r="1.5" />
          <polyline points="21 15 16 10 5 21" />
        </svg>
        <p class="text-xs font-medium text-gray-400">{item.category}</p>
        <p class="text-[10px] text-gray-300">Próximamente</p>
      </div>

      {/* Overlay con mensaje elegante (hover) */}
      <div class="absolute inset-0 flex items-end bg-gradient-to-t from-black/40 to-transparent p-4 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
        <span class="rounded-full bg-brand-accent/90 px-3 py-0.5 text-xs font-medium text-brand-dark">
          Foto real próximamente
        </span>
      </div>
    </div>
  ))}
</div>