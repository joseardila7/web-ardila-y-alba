---
// =============================================
// MAPPLACEHOLDER — Mapa placeholder
// =============================================
// Bloque visual que representa un mapa.
// Cuando tengas dirección real, sustituye
// el contenido por un iframe de Google Maps.
//
// PARA SUSTITUIR POR MAPA REAL:
//   <iframe
//     src="https://www.google.com/maps/embed?pb=!1m18!..."
//     width="100%"
//     height="100%"
//     style="border:0;"
//     allowfullscreen=""
//     loading="lazy"
//   ></iframe>
// =============================================

import { CONTACT } from "../data/contact";

export interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class={`overflow-hidden rounded-xl animate-fade-up ${className}`} style="animation-delay: 200ms; animation-fill-mode: both;">
  <div class="flex aspect-[16/9] items-center justify-center bg-gradient-to-br from-brand-surface-alt to-gray-200">
    <div class="text-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto mb-3 h-14 w-14 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
      </svg>
      <p class="text-sm font-medium text-gray-400">Ubicación</p>
      <p class="mt-1 text-xs text-gray-300">Villanueva del Trabuco, Málaga</p>
      <p class="mt-3 text-xs text-gray-300">📍 Componente sin usar — reemplazado por MapEmbed.astro.</p>
    </div>
  </div>
</div>
