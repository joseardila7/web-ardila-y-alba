---
import { NAV_LINKS } from "../data/navigation";
import { COMPANY } from "../data/company";

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="sticky top-0 z-50 border-b border-white/10 bg-brand-dark transition-shadow duration-200 will-change-shadow">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 md:px-6">
    <!-- LOGO -->
    <a href="/" class="flex items-center gap-3 no-underline" aria-label="Ir a inicio">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-accent transition-transform duration-200 hover:scale-105" aria-hidden="true">
        <svg class="h-6 w-6 text-brand-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
        </svg>
      </div>
      <span class="hidden text-lg font-bold tracking-tight text-white sm:inline">
        {COMPANY.shortName}
      </span>
    </a>

    <!-- Right side: hamburger (mobile) + nav links (desktop) -->
    <div class="flex items-center gap-1">
      <!-- Hamburger button -->
      <button
        id="menu-toggle"
        class="flex h-11 w-11 items-center justify-center rounded-lg text-white md:hidden"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
      >
        <svg id="menu-icon" class="h-6 w-6 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-close-icon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Mobile menu (hidden on desktop) -->
      <ul
        id="nav-menu"
        class="invisible flex-col gap-1 opacity-0 md:visible md:relative md:flex md:flex-row md:items-center md:gap-0 md:opacity-100 md:transform-none"
      >
        {NAV_LINKS.map((link) => {
          const isActive =
            link.href === "/"
              ? currentPath === "/"
              : currentPath.startsWith(link.href);

          return (
            <li>
              <a
                href={link.href}
                class={`group relative block rounded-lg px-3 py-2 text-sm no-underline transition-colors duration-200 ${
                  isActive
                    ? "bg-brand-accent/10 font-medium text-brand-accent"
                    : "text-white/80 hover:bg-white/10 hover:text-white"
                }`}
                aria-current={isActive ? "page" : undefined}
              >
                <span class="relative">
                  {link.label}
                  <span class="absolute -bottom-0.5 left-0 h-0.5 w-0 bg-brand-accent transition-[width] duration-300 motion-safe:group-hover:w-full" aria-hidden="true"></span>
                </span>
              </a>
            </li>
          );
        })}
        <li>
          <a
            href="/presupuesto"
            class="block rounded-lg px-4 py-2 text-sm font-semibold no-underline transition-colors duration-200 bg-brand-accent text-brand-dark hover:bg-brand-accent/90 hover:scale-[1.02] active:scale-[0.98]"
          >
            Presupuesto
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<style>
  /* Mobile menu animation — optimizada: solo opacity + transform */
  @media (max-width: 767px) {
    #nav-menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      display: flex;
      flex-direction: column;
      background: #0c0a20;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      padding: 1rem;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
      transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s ease;
      transform: translateY(-6px);
    }

    #nav-menu.mobile-open {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
  }
</style>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("nav-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("menu-close-icon");
  const header = document.getElementById("site-header");

  function openMenu() {
    if (!menu || !toggle) return;
    menu.classList.add("mobile-open");
    menu.classList.remove("invisible", "opacity-0");
    if (menuIcon && closeIcon) {
      menuIcon.classList.add("hidden");
      closeIcon.classList.remove("hidden");
    }
    toggle.setAttribute("aria-expanded", "true");
    toggle.setAttribute("aria-label", "Cerrar menú de navegación");
  }

  function closeMenu() {
    if (!menu || !toggle) return;
    menu.classList.remove("mobile-open");
    if (menuIcon && closeIcon) {
      menuIcon.classList.remove("hidden");
      closeIcon.classList.add("hidden");
    }
    toggle.setAttribute("aria-expanded", "false");
    toggle.setAttribute("aria-label", "Abrir menú de navegación");
    setTimeout(() => {
      if (!menu.classList.contains("mobile-open")) {
        menu.classList.add("invisible", "opacity-0");
      }
    }, 300);
  }

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = menu.classList.contains("mobile-open");
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    // Close on Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menu.classList.contains("mobile-open")) {
        closeMenu();
        toggle.focus();
      }
    });

    // Close on click outside
    document.addEventListener("click", (e) => {
      if (
        menu.classList.contains("mobile-open") &&
        !header?.contains(e.target)
      ) {
        closeMenu();
      }
    });

    // Close menu when clicking a link inside
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => closeMenu());
    });
  }

  // Dynamic shadow on scroll — throttled with rAF
  if (header) {
    let ticking = false;
    const update = () => {
      if (window.scrollY > 10) {
        header.classList.add("shadow-md", "shadow-black/20", "border-white/20");
      } else {
        header.classList.remove("shadow-md", "shadow-black/20", "border-white/20");
      }
      ticking = false;
    };
    window.addEventListener("scroll", () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
  }
</script>
