---
// =============================================
// HEADER — Barra de navegación principal
// =============================================
// Animaciones incluidas:
//   - Sombra dinámica al hacer scroll
//   - Menú móvil con animación slide-down
//   - Hover en enlaces con subrayado animado
//   - Enlace activo resaltado
// =============================================

import { NAV_LINKS } from "../data/navigation";
import { COMPANY, LOGO } from "../data/company";

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="sticky top-0 z-50 border-b border-white/10 bg-brand-dark transition-colors duration-200">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 md:px-6">
    <!-- ════════════════════════════════════════
         LOGO / NOMBRE DE LA EMPRESA
         ════════════════════════════════════════ -->
    <a href="/" class="flex items-center gap-3 no-underline" aria-label="Ir a inicio">
      <!-- Logo SVG placeholder profesional (sustituir por <img> con logo real) -->
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-accent transition-transform duration-200 hover:scale-105" aria-hidden="true">
        <svg class="h-6 w-6 text-brand-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
        </svg>
      </div>

      <!-- Nombre de la empresa (se oculta en móvil muy pequeño) -->
      <span class="hidden text-lg font-bold tracking-tight text-white sm:inline hover:text-brand-accent transition-colors">
        {COMPANY.shortName}
      </span>
    </a>

    <!-- ════════════════════════════════════════
         BOTÓN HAMBURGUESA (móvil / tablet)
         ════════════════════════════════════════ -->
    <button
      id="menu-toggle"
      class="flex items-center justify-center rounded-lg p-2 text-white md:hidden"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
    >
      <!-- Icono hamburguesa -->
      <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <!-- Icono de cierre (X) -->
      <svg id="menu-close-icon" xmlns="http://www.w3.org/2000/svg" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- ════════════════════════════════════════
         ENLACES DE NAVEGACIÓN + BOTÓN CTA
         ════════════════════════════════════════ -->
    <ul id="nav-menu" class="hidden flex-col gap-1 md:flex md:flex-row md:items-center">
      {NAV_LINKS.map((link) => {
        const isActive =
          link.href === "/"
            ? currentPath === "/"
            : currentPath.startsWith(link.href);

        return (
          <li>
            <a
              href={link.href}
              class={`relative block rounded-lg px-3 py-2 text-sm no-underline transition-colors duration-200 ${
                isActive
                  ? "bg-brand-accent/10 font-medium text-brand-accent"
                  : "text-white/80 hover:bg-white/10 hover:text-white"
              }`}
              aria-current={isActive ? "page" : undefined}
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>

<!-- Script para menú hamburguesa y sombra al hacer scroll -->
<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("nav-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("menu-close-icon");
  const header = document.getElementById("site-header");

  function cerrarMenu() {
    if (!menu || !toggle) return;
    menu.classList.add("hidden");
    menu.classList.remove(
      "animate-slide-down",
      "absolute",
      "top-full",
      "left-0",
      "right-0",
      "flex-col",
      "bg-brand-dark",
      "border-b",
      "border-white/10",
      "p-4",
      "shadow-lg",
      "shadow-black/20"
    );
    if (menuIcon && closeIcon) {
      menuIcon.classList.remove("hidden");
      closeIcon.classList.add("hidden");
    }
    toggle.setAttribute("aria-expanded", "false");
  }

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isHidden = menu.classList.contains("hidden");
      toggle.setAttribute("aria-expanded", String(!isHidden));

      if (menuIcon && closeIcon) {
        menuIcon.classList.toggle("hidden");
        closeIcon.classList.toggle("hidden");
      }

      if (isHidden) {
        menu.classList.remove("hidden");
        // Usamos animate-slide-down en lugar de animate-fade-in
        menu.classList.add(
          "animate-slide-down",
          "absolute",
          "top-full",
          "left-0",
          "right-0",
          "flex-col",
          "bg-brand-dark",
          "border-b",
          "border-white/10",
          "p-4",
          "shadow-lg",
          "shadow-black/20"
        );
      } else {
        cerrarMenu();
      }
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => cerrarMenu());
    });
  }

  // Sombra dinámica en header al hacer scroll (passive listener para no bloquear)
  if (header) {
    window.addEventListener("scroll", () => {
      if (window.scrollY > 10) {
        header.classList.add("shadow-md", "shadow-black/20", "border-white/20");
      } else {
        header.classList.remove("shadow-md", "shadow-black/20", "border-white/20");
      }
    }, { passive: true });
  }
</script>
