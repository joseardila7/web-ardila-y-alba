---
// =============================================
// HERO — Portada principal
// =============================================
// Sin animaciones pesadas ni decoraciones con blur.
// Solo entrada suave escalonada en textos y botones.
//
// Los textos se leen de src/data/company.ts y src/data/home.ts
// =============================================

import { COMPANY } from "../data/company";
import { CONTACT } from "../data/contact";
import { HERO } from "../data/home";
import Button from "./Button.astro";
---

<section class="relative flex min-h-[85vh] items-center justify-center overflow-hidden bg-gradient-to-br from-brand-dark via-brand-primary to-brand-medium px-4">
  <!-- ════════════════════════════════════════
       FONDO DECORATIVO (patrón de puntos)
       ════════════════════════════════════════ -->
  <div class="absolute inset-0 opacity-[0.04]" aria-hidden="true">
    <div class="h-full w-full" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>

  <!-- Elementos decorativos estáticos ligeros -->
  <div class="pointer-events-none absolute -right-32 -top-32 h-64 w-64 rounded-full bg-brand-accent/[0.03]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -bottom-32 -left-32 h-64 w-64 rounded-full bg-brand-light/[0.03]" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-4xl px-4 text-center">
    <!-- Etiqueta de categoría — entrada: fade-in -->
    <span class="mb-6 inline-block animate-fade-in rounded-full border border-brand-accent/30 bg-brand-accent/10 px-4 py-1 text-sm font-medium text-brand-accent-light [animation-delay:100ms] [animation-fill-mode:both]">
      {HERO.badge}
    </span>

    <!-- Título principal <h1> — entrada: fade-up -->
    <h1 class="mb-6 animate-fade-up text-4xl font-bold leading-tight tracking-tight text-white md:text-5xl lg:text-6xl [animation-delay:300ms] [animation-fill-mode:both]">
      {COMPANY.shortName}
    </h1>

    <!-- Subtítulo — entrada: fade-up con más retardo -->
    <p class="mb-10 animate-fade-up text-lg text-white/80 md:text-xl [animation-delay:500ms] [animation-fill-mode:both]">
      {HERO.subtitle}
    </p>

    <!-- ════════════════════════════════════════
         BOTONES DE ACCIÓN
         Entrada escalonada con fade-up
         ════════════════════════════════════════ -->
    <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
      <!-- Botón principal: Contactar (destaca sobre los demás) -->
      <div class="animate-fade-up [animation-delay:700ms] [animation-fill-mode:both]">
        <Button variant="accent" size="lg" href="/contacto">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
            <line x1="16" y1="13" x2="8" y2="13" />
            <line x1="16" y1="17" x2="8" y2="17" />
            <polyline points="10 9 9 9 8 9" />
          </svg>
          {CONTACT.quoteLabel}
        </Button>
      </div>

      <!-- Botón: Llamar -->
      <div class="animate-fade-up [animation-delay:800ms] [animation-fill-mode:both]">
        <Button variant="primary" size="lg" href={`tel:${CONTACT.phoneLink}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
          {CONTACT.callLabel}
        </Button>
      </div>

      <!-- Botón: WhatsApp -->
      <div class="animate-fade-up [animation-delay:900ms] [animation-fill-mode:both]">
        <Button
          variant="outline"
          size="lg"
          href={`https://wa.me/${CONTACT.whatsappLink}?text=${encodeURIComponent(CONTACT.whatsappMessage)}`}
          target="_blank"
          rel="noreferrer"
          class="border-white/70 text-white hover:bg-white hover:text-brand-primary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" />
          </svg>
          {CONTACT.whatsappLabel}
        </Button>
      </div>
    </div>
  </div>
</section>
