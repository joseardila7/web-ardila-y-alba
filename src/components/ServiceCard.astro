---
import type { Service } from "../data/services";

export interface Props {
  service: Service;
  href?: string;
}

const { service, href } = Astro.props;
---

<article class="group relative flex flex-col rounded-xl bg-white p-6 shadow-sm card-hover card-glow">
  {service.category && (
    <span class="absolute right-4 top-4 rounded-full bg-brand-accent/10 px-3 py-0.5 text-xs font-medium text-brand-accent-dark transition-colors duration-200 group-hover:bg-brand-accent/15">
      {service.category}
    </span>
  )}

  <div
    class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-brand-primary/5 text-xl transition-[transform,background-color] duration-300 group-hover:scale-110 group-hover:bg-brand-accent/10"
    aria-hidden="true"
  >
    <span>{service.icon}</span>
  </div>

  <h3 class="mb-2 text-xl font-semibold text-brand-dark transition-colors duration-200 group-hover:text-brand-accent">
    {service.title}
  </h3>

  <p class="mb-4 flex-1 text-gray-600 leading-relaxed">
    {service.description}
  </p>

  {href && (
    <a
      href={href}
      class="mt-auto inline-flex items-center gap-1.5 text-sm font-medium text-brand-accent transition-colors duration-200 hover:text-brand-accent-dark group/link"
    >
      Ver servicio
      <span aria-hidden="true" class="text-base link-arrow">→</span>
    </a>
  )}
</article>
