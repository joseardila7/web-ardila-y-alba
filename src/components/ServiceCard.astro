---
// =============================================
// SERVICECARD — Tarjeta de servicio individual
// =============================================
// Efectos hover sutiles:
//   - Elevación mínima + sombra suave
//   - Color de fondo del icono ligeramente más intenso
//   - Categoría cambia de fondo
//   - Flecha se desplaza ligeramente
//
// Los datos se leen de src/data/services.ts
// =============================================

import type { Service } from "../data/services";

export interface Props {
  service: Service;
}

const { service } = Astro.props;
---

<article class="group relative flex flex-col rounded-xl bg-white p-6 shadow-sm transition-colors duration-200 hover:border-brand-accent/20 hover:shadow-sm">  
  <!-- Categoría (etiqueta decorativa arriba a la derecha) -->
  {service.category && (
    <span class="absolute right-4 top-4 rounded-full bg-brand-accent/10 px-3 py-0.5 text-xs font-medium text-brand-accent-dark transition-colors duration-200 group-hover:bg-brand-accent/15">
      {service.category}
    </span>
  )}

  <!-- Icono del servicio con fondo decorativo -->
  <div
    class="mb-4 flex h-14 w-14 items-center justify-center rounded-lg bg-brand-primary/5 text-2xl transition-colors duration-200 group-hover:bg-brand-accent/10"
    aria-hidden="true"
  >
    <span>{service.icon}</span>
  </div>

  <!-- Título del servicio -->
  <h3 class="mb-2 text-xl font-semibold text-brand-dark">
    {service.title}
  </h3>

  <!-- Descripción -->
  <p class="mb-4 flex-1 text-gray-600 leading-relaxed">
    {service.description}
  </p>

  <!-- Enlace "Ver servicio" (placeholder, sin página de detalle todavía) -->
  <a
    href="/servicios"
    class="mt-auto inline-flex items-center gap-1.5 text-sm font-medium text-brand-accent transition-colors duration-200 hover:text-brand-accent-dark"
  >
    Ver servicio
    <span aria-hidden="true" class="text-base">→</span>
  </a>
</article>
