---
import Layout from "../../layouts/Layout.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import CTABanner from "../../components/CTABanner.astro";
import RelatedServices from "../../components/RelatedServices.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { SERVICES } from "../../data/services";

export async function getStaticPaths() {
  return SERVICES.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const canonicalUrl = `https://ardilayalba.com/servicios/${service.slug}`;
---

<Layout
  title={`${service.title} | Servicios`}
  description={`${service.description} ${"Ardila y Alba Instalaciones"} en Villanueva del Trabuco y Málaga. Solicita presupuesto sin compromiso.`}
  canonical={canonicalUrl}
>
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-dark via-brand-primary to-brand-medium px-4 pt-28 pb-20 md:pt-36 md:pb-28">
    <div class="pointer-events-none absolute -right-20 -top-20 h-72 w-72 rounded-full bg-brand-accent/[0.03]" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-brand-light/[0.03]" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-4xl text-center animate-fade-up">
      <Breadcrumbs crumbs={[{ label: "Servicios", href: "/servicios" }, { label: service.title }]} />
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-brand-accent/15 text-3xl" aria-hidden="true">
        {service.icon}
      </div>
      <h1 class="mb-4 text-4xl font-bold text-white md:text-5xl">
        {service.title}
      </h1>
      <p class="mx-auto max-w-2xl text-lg text-white/70">
        {service.description}
      </p>
    </div>
  </section>

  {service.benefits && service.benefits.length > 0 && (
    <section class="px-4 py-20 md:py-28 reveal-up">
      <div class="mx-auto max-w-5xl">
        <SectionTitle
          title="¿Qué incluye este servicio?"
          subtitle="Detalles de lo que puede incluir el servicio, según las características de cada trabajo."
        />
        <div class="grid gap-4 sm:grid-cols-2">
          {service.benefits.map((benefit, i) => (
            <div
              class="reveal-up flex items-start gap-4 rounded-xl bg-white p-5 shadow-sm transition-[transform,box-shadow] duration-300 hover:-translate-y-0.5 hover:shadow-md"
              style={`transition-delay: ${i * 80}ms`}
            >
              <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-accent/10 text-sm font-bold text-brand-accent" aria-hidden="true">
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              </span>
              <p class="text-gray-700">{benefit}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {service.whenToContact && service.whenToContact.length > 0 && (
    <section class="bg-brand-surface-alt px-4 py-20 md:py-28 reveal-up">
      <div class="mx-auto max-w-5xl">
        <SectionTitle
          title="¿Cuándo puede interesarte?"
          subtitle="Situaciones habituales en las que este servicio suele ser necesario."
        />
        <div class="grid gap-4 sm:grid-cols-2">
          {service.whenToContact.map((item, i) => (
            <div
              class="reveal-up flex items-start gap-4 rounded-xl border border-gray-100 bg-white p-5 shadow-sm transition-[transform,box-shadow] duration-300 hover:-translate-y-0.5 hover:shadow-md"
              style={`transition-delay: ${i * 80}ms`}
            >
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-primary/10 text-sm font-bold text-brand-primary">{i + 1}</span>
              <p class="pt-1 text-gray-700">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {service.relatedServices && service.relatedServices.length > 0 && (
    <section class="px-4 py-20 md:py-28 reveal-up">
      <div class="mx-auto max-w-7xl">
        <SectionTitle
          title="Servicios relacionados"
          subtitle="Otros servicios que pueden complementar o estar relacionados con este."
        />
        <RelatedServices slugs={service.relatedServices} currentSlug={service.slug} />
      </div>
    </section>
  )}

  <CTABanner
    title={`¿Necesitas información sobre ${service.title.toLowerCase()}?`}
    subtitle="Cuéntanos qué necesitas y te orientamos sin compromiso sobre la mejor solución para tu caso."
  />
</Layout>
