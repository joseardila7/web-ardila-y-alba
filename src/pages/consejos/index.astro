---
import Layout from "../../layouts/Layout.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import CTABanner from "../../components/CTABanner.astro";
import { CONSEJOS } from "../../data/consejos";
import { COMPANY } from "../../data/company";
---

<Layout
  title="Consejos y artículos"
  description={`Consejos útiles sobre instalaciones eléctricas, climatización y eficiencia energética de ${COMPANY.shortName}. Información práctica para tus proyectos.`}
>
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-dark via-brand-primary to-brand-medium px-4 py-20 md:py-28">
    <div class="pointer-events-none absolute -right-20 -top-20 h-72 w-72 rounded-full bg-brand-accent/[0.03]" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-brand-light/[0.03]" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-4xl text-center animate-fade-up">
      <h1 class="mb-4 text-4xl font-bold text-white md:text-5xl">
        Consejos y artículos
      </h1>
      <p class="mx-auto max-w-2xl text-lg text-white/70">
        Información útil y práctica sobre instalaciones eléctricas, climatización, eficiencia energética y mantenimiento.
      </p>
    </div>
  </section>

  <section class="reveal-up px-4 py-20 md:py-28">
    <div class="mx-auto max-w-7xl">
      <SectionTitle
        title="Artículos recomendados"
        subtitle="Contenido pensado para ayudarte a tomar decisiones informadas sobre tus proyectos."
      />

      <div class="reveal-up grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {CONSEJOS.map((article, i) => (
          <a
            href={`/consejos/${article.slug}`}
            class="reveal-up group block no-underline"
            style={`transition-delay: ${i * 100}ms`}
          >
            <article class="card-hover flex h-full flex-col rounded-xl border border-gray-100 bg-white p-6 shadow-sm transition-colors duration-200 hover:border-brand-accent/30">
              <div class="mb-3 flex items-center gap-2">
                <span class="rounded-full bg-brand-accent/10 px-2.5 py-0.5 text-xs font-medium text-brand-accent-dark">
                  {article.category}
                </span>
                <span class="text-xs text-gray-400">{article.date}</span>
              </div>
              <h2 class="mb-2 text-lg font-bold text-brand-dark transition-colors duration-200 group-hover:text-brand-accent">
                {article.title}
              </h2>
              <p class="flex-1 text-sm leading-relaxed text-gray-600">
                {article.description}
              </p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-brand-accent transition-[gap,color] duration-200 group-hover:gap-1.5 group-hover:text-brand-accent-dark">
                Leer artículo
                <span aria-hidden="true" class="arrow-right text-base">→</span>
              </span>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    title="¿Tienes un proyecto en mente?"
    subtitle="Cuéntanos qué necesitas y te orientaremos sin compromiso."
  />
</Layout>
