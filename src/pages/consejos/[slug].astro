---
import Layout from "../../layouts/Layout.astro";
import CTABanner from "../../components/CTABanner.astro";
import { CONSEJOS } from "../../data/consejos";
import type { ArticleBlock } from "../../data/consejos";

export async function getStaticPaths() {
  return CONSEJOS.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const related = CONSEJOS.filter((a) => a.slug !== article.slug).slice(0, 3);
---

<Layout
  title={article.title}
  description={article.description}
>
  <section class="reveal-up px-4 py-20 md:py-28">
    <div class="mx-auto max-w-3xl">
      <div class="mb-8">
        <a href="/consejos" class="group inline-flex items-center gap-1.5 text-sm font-medium text-brand-accent no-underline transition-colors duration-200 hover:text-brand-accent-dark">
          <span aria-hidden="true" class="link-arrow text-base">←</span>
          Volver a consejos
        </a>
      </div>

      <article class="reveal-up">
        <div class="mb-4 flex items-center gap-3">
          <span class="rounded-full bg-brand-accent/10 px-3 py-0.5 text-xs font-medium text-brand-accent-dark">
            {article.category}
          </span>
          <span class="text-xs text-gray-400">{article.date}</span>
        </div>

        <h1 class="mb-6 text-3xl font-bold text-brand-dark md:text-4xl">
          {article.title}
        </h1>

        <div class="space-y-5">
          {article.blocks.map((block) => (
            <>
              {block.type === "paragraph" && (
                <p class="text-base leading-relaxed text-gray-700">
                  {block.text}
                </p>
              )}

              {block.type === "heading" && (
                <h2 class="pt-2 text-xl font-bold text-brand-dark">
                  {block.text}
                </h2>
              )}

              {block.type === "list" && block.items && (
                <ul class="space-y-2">
                  {block.items.map((item) => (
                    <li class="flex items-start gap-3 text-base text-gray-700">
                      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-accent" aria-hidden="true"></span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              )}

              {block.type === "note" && (
                <div class="mt-6 rounded-xl border border-gray-200 bg-brand-surface-alt px-5 py-4">
                  <p class="text-sm leading-relaxed text-gray-500">
                    {block.text}
                  </p>
                </div>
              )}
            </>
          ))}
        </div>
      </article>

      {related.length > 0 && (
        <div class="reveal-up mt-16 border-t border-gray-100 pt-10">
          <h2 class="mb-6 text-2xl font-bold text-brand-dark">Artículos relacionados</h2>
          <div class="reveal-up grid gap-4 sm:grid-cols-3">
            {related.map((a, i) => (
              <a href={`/consejos/${a.slug}`} class="reveal-up group block no-underline" style={`transition-delay: ${i * 100}ms;`}>
                <article class="card-hover rounded-xl border border-gray-100 bg-white p-5 shadow-sm transition-colors duration-200 hover:border-brand-accent/30">
                  <span class="mb-1 inline-block rounded-full bg-brand-accent/10 px-2 py-0.5 text-xs font-medium text-brand-accent-dark">
                    {a.category}
                  </span>
                  <h3 class="text-sm font-bold text-brand-dark transition-colors duration-200 group-hover:text-brand-accent">
                    {a.title}
                  </h3>
                </article>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <CTABanner
    title="¿Necesitas ayuda profesional?"
    subtitle="Contacta con nosotros y te orientaremos sin compromiso."
  />
</Layout>
