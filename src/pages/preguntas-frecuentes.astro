---
import Layout from "../layouts/Layout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import CTABanner from "../components/CTABanner.astro";
import { FAQS } from "../data/faqs";
import { COMPANY } from "../data/company";
---

<Layout
  title="Preguntas frecuentes"
  description={`Resuelve tus dudas sobre instalaciones eléctricas, presupuestos y servicios de ${COMPANY.shortName}. Preguntas frecuentes sobre electricidad, climatización y más.`}
>
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-dark via-brand-primary to-brand-medium px-4 py-20 md:py-28">
    <div class="pointer-events-none absolute -right-20 -top-20 h-72 w-72 rounded-full bg-brand-accent/[0.03]" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-brand-light/[0.03]" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-4xl text-center animate-fade-up">
      <h1 class="mb-4 text-4xl font-bold text-white md:text-5xl">
        Preguntas frecuentes
      </h1>
      <p class="mx-auto max-w-2xl text-lg text-white/70">
        Resolvemos las dudas más comunes sobre nuestros servicios. Si no encuentras lo que buscas, contacta con nosotros.
      </p>
    </div>
  </section>

  <section class="reveal-up px-4 py-20 md:py-28">
    <div class="mx-auto max-w-3xl">
      <SectionTitle
        title="Dudas frecuentes"
        subtitle="Respuestas a las preguntas que más nos hacen nuestros clientes."
      />

      <div class="reveal-up space-y-3">
        {FAQS.map((faq, i) => (
          <details
            class="reveal-up card-hover group overflow-hidden rounded-xl border border-gray-100 bg-white shadow-sm transition-colors duration-200 hover:border-brand-accent/30"
            style={`transition-delay: ${i * 50}ms;`}
          >
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 text-left font-medium text-brand-dark transition-colors duration-200 hover:text-brand-accent [&::-webkit-details-marker]:none">
              <span>{faq.question}</span>
              <svg class="h-5 w-5 shrink-0 text-gray-400 transition-transform duration-200 group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
              </svg>
            </summary>
            <div class="border-t border-gray-100 px-6 py-4">
              <p class="text-sm leading-relaxed text-gray-600">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    title="¿Tienes otra pregunta?"
    subtitle="Estaremos encantados de resolver tus dudas personalmente."
  />
</Layout>
