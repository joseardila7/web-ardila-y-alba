# =============================================
# VARIABLES DE ENTORNO (EJEMPLO)
# =============================================
# Crea un archivo .env en la raíz del proyecto
# copiando este archivo y completa los valores
# reales cuando estén disponibles.
#
# Estas variables se usan en los archivos de
# src/data/ para centralizar la configuración.
#
# NOTA: En Astro, las variables públicas deben
# empezar por PUBLIC_ para estar disponibles
# en el cliente.
# =============================================

# URL del sitio web (cuando tengas dominio)
PUBLIC_SITE_URL=https://ejemplo.com

# Email de contacto de la empresa
PUBLIC_CONTACT_EMAIL=email@ejemplo.com

# Teléfono de contacto (con código internacional)
PUBLIC_CONTACT_PHONE=+34000000000
